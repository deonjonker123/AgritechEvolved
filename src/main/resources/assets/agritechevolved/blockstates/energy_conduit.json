{
  "multipart": [
    {
      "apply": { "model": "agritechevolved:block/energy_conduit_core" }
    },
    {
      "when": { "up": "true" },
      "apply": { "model": "agritechevolved:block/energy_conduit_side", "uvlock": true }
    },
    {
      "when": { "down": "true" },
      "apply": { "model": "agritechevolved:block/energy_conduit_side", "x": 180, "uvlock": true }
    },
    {
      "when": { "south": "true" },
      "apply": { "model": "agritechevolved:block/energy_conduit_side", "x": 90, "y": 180, "uvlock": true }
    },
    {
      "when": { "north": "true" },
      "apply": { "model": "agritechevolved:block/energy_conduit_side", "x": 90, "uvlock": true }
    },
    {
      "when": { "east": "true" },
      "apply": { "model": "agritechevolved:block/energy_conduit_side", "x": 90, "y": 90, "uvlock": true }
    },
    {
      "when": { "west": "true" },
      "apply": { "model": "agritechevolved:block/energy_conduit_side", "x": 90, "y": 270, "uvlock": true }
    }
  ]
}
